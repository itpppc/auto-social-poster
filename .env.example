# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าของคุณ
# รัน: copy .env.example .env

# ===================================================
# [1] GEMINI API KEY (จำเป็น — ฟรี)
# สมัคร: https://aistudio.google.com/ → Get API Key
# ===================================================
GEMINI_API_KEY=AIza...

# ===================================================
# [2] FACEBOOK (จำเป็นถ้าเปิด Facebook)
# วิธีรับ: ดู STEP 7 ใน README.md
# ===================================================
FACEBOOK_PAGE_ID=123456789
FACEBOOK_ACCESS_TOKEN=EAA...

# ===================================================
# [3] LINE Messaging API (จำเป็นถ้าเปิด LINE)
# สมัคร: https://developers.line.biz/
# ===================================================
LINE_CHANNEL_ACCESS_TOKEN=

# ===================================================
# [4] TIKTOK (ไม่บังคับ — ต้องการ video file)
# ===================================================
TIKTOK_ACCESS_TOKEN=

# ===================================================
# [5] CONTENT SETTINGS
# ===================================================
CONTENT_NICHE=ความรู้การเงินและการลงทุน

# เปิด/ปิด platform (true/false)
ENABLE_FACEBOOK=true
ENABLE_LINE=true
ENABLE_TIKTOK=false
