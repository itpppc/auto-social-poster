# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าของคุณ
# รัน: copy .env.example .env

# ===================================================
# [1] GEMINI API KEY (จำเป็น — ฟรี)
# สมัคร: https://aistudio.google.com/ → Get API Key
# ===================================================
GEMINI_API_KEY=AIza...

# ===================================================
# [2] FACEBOOK (จำเป็นถ้าเปิด Facebook)
# วิธีรับ: ดู STEP 7 ใน README.md
# ===================================================
FACEBOOK_PAGE_ID=123456789
FACEBOOK_ACCESS_TOKEN=EAA...

# ===================================================
# [3] LINE Messaging API (จำเป็นถ้าเปิด LINE)
# สมัคร: https://developers.line.biz/
# ===================================================
LINE_CHANNEL_ACCESS_TOKEN=

# ===================================================
# [4] TIKTOK (ไม่บังคับ — ต้องการ video file)
# ===================================================
TIKTOK_ACCESS_TOKEN=

# ===================================================
# [5] CONTENT SETTINGS
# ===================================================
CONTENT_NICHE=ความรู้การเงินและการลงทุน

# เปิด/ปิด platform (true/false)
ENABLE_FACEBOOK=true
ENABLE_LINE=true
ENABLE_TIKTOK=false

# ===================================================
# [6] CATCH-UP POSTING (โพสต์ชดเชยรอบที่ขาด)
# ตรวจตอน Scheduler start ว่าวันนี้รอบไหนยังไม่ได้โพสต์
# แล้วโพสต์ชดเชยอัตโนมัติ
# ===================================================
ENABLE_CATCHUP=true              # true/false
CATCHUP_MAX_AGE_HOURS=12         # ไม่ชดเชยรอบที่เก่ากว่า X ชั่วโมง
CATCHUP_DELAY_SECONDS=60         # หน่วงระหว่างรอบ (กัน rate limit)
CATCHUP_SKIP_GRACE_MINUTES=5     # รอบที่เพิ่งผ่าน X นาที ให้ scheduler ปกติทำ
